<div class="theme-toggle">
  <div class="toggle-container" id="theme-toggle">
    <div class="toggle-icons">
      <svg class="toggle-icon sun-icon" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd" />
      </svg>
      <svg class="toggle-icon moon-icon" fill="currentColor" viewBox="0 0 20 20">
        <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z" />
      </svg>
    </div>
    <div class="toggle-track">
      <div class="toggle-thumb"></div>
    </div>
  </div>
</div>

<div class="navbar">
  <a href="/" class="navbar-brand">Dashboard Financeiro</a>
</div>

<div class="content-container">
  <h1>Cotações das moedas mundiais e notícias financeiras</h1>

  <div class="auth-links">
    <% if user_signed_in? %>
      <p><strong>Usuário logado:</strong> <%= current_user.email %></p>
      <%= button_to "Logout", destroy_user_session_path, method: :delete, class: "btn-logout" %>
    <% else %>
      <p><%= link_to "Fazer Login", new_user_session_path, class: "btn-login" %></p>
    <% end %>
  </div>

  <!-- Currency Table Section -->
  <div class="market-section">
    <h2>Cotações de Moedas</h2>
    <div class="currency-table-container">
      <table class="currency-table">
        <thead>
          <tr>
            <th>Moeda</th>
            <th>Código</th>
            <th>Valor (USD)</th>
            <th>Variação 24h</th>
          </tr>
        </thead>
        <tbody>
          <% @currencies.each do |currency| %>
            <tr>
              <td class="currency-name">
                <span class="currency-flag"><%= currency_flag(currency[:code]) %></span>
                <%= currency[:name] %>
              </td>
              <td class="currency-code"><%= currency[:code] %></td>
              <td class="currency-rate"><%= number_with_precision(currency[:rate], precision: 4) %></td>
              <td class="currency-change <%= currency[:change] >= 0 ? 'positive' : 'negative' %>">
                <%= currency[:change] >= 0 ? '↗' : '↘' %>
                <%= number_with_precision(currency[:change].abs, precision: 2) %>%
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Financial News Section -->
  <div class="market-section">
    <h2>📰 Notícias do Mercado Financeiro</h2>
    <div class="news-container">
      <% @financial_news.each do |news| %>
        <div class="news-item">
          <div class="news-header">
            <span class="news-category"><%= news[:category] %></span>
            <span class="news-time"><%= news[:time] %></span>
          </div>
          <h3 class="news-title"><%= news[:title] %></h3>
          <p class="news-summary"><%= news[:summary] %></p>
          <div class="news-source">
            <span class="source-name"><%= news[:source] %></span>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <div style="margin-top: 24px;">
    <p><%= @test %></p>
  </div>
</div>